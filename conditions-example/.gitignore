# Local .terraform directories (contains provider plugins and modules)
.terraform/

# .tfstate files (contains sensitive infrastructure data and backend info)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (likely to contain sensitive data, passwords, and API keys)
*.tfvars
*.tfvars.json

# Ignore override files (used for local modifications)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created during terraform apply
.terraform.tfstate.lock.info

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Optional: Ignore plan files generated by terraform plan -out=tfplan
*tfplan*